{
  "brand": {
    "name": "Awestruck Spa Club",
    "nameShort": "Awestruck",
    "tagline": "Where Relaxation Meets Artistry",
    "yearFounded": 2015,
    "registeredTrademark": true,
    "website": "",
    "social": {
      "instagram": "@AwestruckSpaClub",
      "facebook": "",
      "tiktok": "",
      "pinterest": ""
    }
  },

  "logo": {
    "description": "AWESTRUCK in two-tone — 'AWE' in metallic silver, 'STRUCK' in crimson red, with ® symbol. Below: 'SPA' (left) and 'CLUB' (right) in white uppercase separated by a spa/massage bed icon. Set on black background with a subtle reflection.",
    "file": "logo.png",
    "fileDark": "logo.png",
    "fileLight": "logo-light.png",
    "minWidth": "120px",
    "clearSpace": "Equal to the height of the letter 'A' in AWESTRUCK on all sides"
  },

  "colors": {
    "primary": {
      "default": "#C41E3A",
      "dark": "#9B1B30",
      "light": "#E8354A",
      "name": "Crimson Red"
    },
    "silver": {
      "default": "#8A8A8A",
      "light": "#B0B0B0",
      "dark": "#5C5C5C",
      "name": "Metallic Silver"
    },
    "neutrals": {
      "black": "#0A0A0A",
      "charcoal": "#1A1A1A",
      "darkGrey": "#2D2D2D",
      "mediumGrey": "#6B6B6B",
      "lightGrey": "#E8E8E8",
      "offWhite": "#F5F5F5",
      "white": "#FFFFFF"
    },
    "semantic": {
      "success": "#22C55E",
      "warning": "#F59E0B",
      "error": "#EF4444",
      "info": "#3B82F6"
    },
    "gradients": {
      "brand": "linear-gradient(135deg, #9B1B30, #C41E3A, #E8354A)",
      "darkFade": "linear-gradient(180deg, #0A0A0A, #1A1A1A)",
      "emberGlow": "linear-gradient(135deg, #0A0A0A 0%, #9B1B30 100%)"
    },
    "darkMode": {
      "bgPrimary": "#0A0A0A",
      "bgSecondary": "#1A1A1A",
      "bgCard": "#2D2D2D",
      "textPrimary": "#FFFFFF",
      "textSecondary": "#6B6B6B",
      "border": "#2D2D2D",
      "accent": "#C41E3A"
    },
    "lightMode": {
      "bgPrimary": "#FFFFFF",
      "bgSecondary": "#F5F5F5",
      "bgCard": "#FFFFFF",
      "textPrimary": "#0A0A0A",
      "textSecondary": "#6B6B6B",
      "border": "#E8E8E8",
      "accent": "#C41E3A"
    }
  },

  "typography": {
    "fonts": {
      "heading": {
        "family": "Playfair Display",
        "fallback": "Georgia, serif",
        "googleImport": "Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;0,900;1,400;1,700",
        "usage": "All headings, display text, logo text"
      },
      "body": {
        "family": "DM Sans",
        "fallback": "system-ui, sans-serif",
        "googleImport": "DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400",
        "usage": "Body text, buttons, labels, navigation, UI elements"
      },
      "accent": {
        "family": "Cormorant Garamond",
        "fallback": "Georgia, serif",
        "googleImport": "Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600",
        "usage": "Quotes, testimonials, decorative text, taglines — always italic"
      }
    },
    "scale": {
      "display": { "size": "4.5rem", "sizeMobile": "2.5rem", "weight": 800, "lineHeight": 1.0, "letterSpacing": "-0.02em", "font": "heading" },
      "h1":      { "size": "3rem",   "sizeMobile": "2rem",   "weight": 700, "lineHeight": 1.1, "letterSpacing": "-0.01em", "font": "heading" },
      "h2":      { "size": "2.25rem","sizeMobile": "1.75rem","weight": 600, "lineHeight": 1.2, "letterSpacing": "0",       "font": "heading" },
      "h3":      { "size": "1.75rem","sizeMobile": "1.375rem","weight": 600, "lineHeight": 1.2, "letterSpacing": "0",      "font": "heading" },
      "h4":      { "size": "1.375rem","sizeMobile":"1.125rem","weight": 500, "lineHeight": 1.3, "letterSpacing": "0",      "font": "heading" },
      "h5":      { "size": "1.125rem","sizeMobile":"1rem",    "weight": 600, "lineHeight": 1.4, "letterSpacing": "0",      "font": "body" },
      "body":    { "size": "1rem",   "sizeMobile": "1rem",   "weight": 400, "lineHeight": 1.6, "letterSpacing": "0",       "font": "body" },
      "small":   { "size": "0.875rem","sizeMobile":"0.875rem","weight": 400, "lineHeight": 1.5, "letterSpacing": "0",      "font": "body" },
      "caption": { "size": "0.75rem","sizeMobile": "0.75rem","weight": 400, "lineHeight": 1.4, "letterSpacing": "0",       "font": "body" },
      "overline":{ "size": "0.75rem","sizeMobile": "0.75rem","weight": 500, "lineHeight": 1.4, "letterSpacing": "0.15em",  "font": "body", "textTransform": "uppercase" }
    }
  },

  "spacing": {
    "baseUnit": 4,
    "scale": [4, 8, 12, 16, 20, 24, 32, 40, 48, 64, 80, 96, 128],
    "sectionPadding": {
      "mobile": "64px",
      "tablet": "96px",
      "desktop": "128px"
    },
    "contentPadding": {
      "mobile": "20px",
      "tablet": "32px",
      "desktop": "64px"
    },
    "maxContentWidth": "1200px"
  },

  "breakpoints": {
    "sm": "480px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },

  "motion": {
    "easing": {
      "easeOut": "cubic-bezier(0, 0, 0.2, 1)",
      "easeIn": "cubic-bezier(0.4, 0, 1, 1)",
      "easeInOut": "cubic-bezier(0.4, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "duration": {
      "instant": "0ms",
      "fast": "150ms",
      "normal": "300ms",
      "slow": "500ms",
      "dramatic": "1000ms"
    },
    "scrollAnimations": {
      "fadeUp": "opacity 0 → 1, translateY(40px) → 0",
      "fadeIn": "opacity 0 → 1",
      "slideInLeft": "translateX(-40px) → 0",
      "slideInRight": "translateX(40px) → 0",
      "scaleUp": "scale(0.9) → 1"
    }
  },

  "components": {
    "borderRadius": {
      "small": "6px",
      "medium": "10px",
      "large": "16px",
      "full": "9999px"
    },
    "buttonSizes": {
      "small": { "height": "32px", "padding": "8px 16px", "fontSize": "12px" },
      "medium": { "height": "40px", "padding": "12px 24px", "fontSize": "14px" },
      "large": { "height": "48px", "padding": "16px 32px", "fontSize": "16px" }
    },
    "inputHeight": "48px",
    "minTouchTarget": "44px",
    "shadows": {
      "small": "0 2px 8px rgba(0,0,0,0.12)",
      "medium": "0 8px 24px rgba(0,0,0,0.2)",
      "large": "0 16px 48px rgba(0,0,0,0.3)",
      "glow": "0 0 24px rgba(196,30,58,0.3)"
    }
  },

  "imagery": {
    "style": "Warm, moody, luxurious. Rich dark tones with warm highlights. Conveys relaxation, transformation, and premium quality.",
    "aspectRatios": {
      "hero": "16:9",
      "featured": "4:3",
      "profile": "1:1",
      "portrait": "3:4",
      "cinematic": "21:9"
    },
    "overlays": {
      "darkGradient": "linear-gradient(to top, rgba(10,10,10,0.9), transparent)",
      "darkFull": "rgba(10,10,10,0.5)",
      "brandTint": "rgba(196,30,58,0.3)"
    }
  },

  "voice": {
    "personality": ["Luxurious", "Bold", "Refined", "Transformative", "Welcoming"],
    "tone": {
      "formalToCasual": 35,
      "seriousToPlayful": 30,
      "traditionalToModern": 70,
      "reservedToBold": 75
    },
    "ctaPatterns": {
      "primary": ["Book Now", "Reserve Your Spot", "Book Your Experience"],
      "secondary": ["Learn More", "Explore Services", "Discover More"],
      "tertiary": ["View All", "Read More", "See Details"]
    },
    "headingCase": "sentence",
    "buttonCase": "title"
  },

  "tailwindConfig": {
    "colors": {
      "primary": { "DEFAULT": "#C41E3A", "dark": "#9B1B30", "light": "#E8354A" },
      "silver": { "DEFAULT": "#8A8A8A", "light": "#B0B0B0", "dark": "#5C5C5C" },
      "charcoal": "#1A1A1A",
      "grey": { "dark": "#2D2D2D", "med": "#6B6B6B", "light": "#E8E8E8" },
      "offwhite": "#F5F5F5"
    },
    "fontFamily": {
      "heading": ["Playfair Display", "Georgia", "serif"],
      "body": ["DM Sans", "system-ui", "sans-serif"],
      "accent": ["Cormorant Garamond", "Georgia", "serif"]
    }
  },

  "cssVariables": {
    "--color-primary": "#C41E3A",
    "--color-primary-dark": "#9B1B30",
    "--color-primary-light": "#E8354A",
    "--color-silver": "#8A8A8A",
    "--color-black": "#0A0A0A",
    "--color-charcoal": "#1A1A1A",
    "--color-dark-grey": "#2D2D2D",
    "--color-medium-grey": "#6B6B6B",
    "--color-light-grey": "#E8E8E8",
    "--color-off-white": "#F5F5F5",
    "--color-white": "#FFFFFF",
    "--font-heading": "'Playfair Display', Georgia, serif",
    "--font-body": "'DM Sans', system-ui, sans-serif",
    "--font-accent": "'Cormorant Garamond', Georgia, serif",
    "--radius-sm": "6px",
    "--radius-md": "10px",
    "--radius-lg": "16px",
    "--shadow-sm": "0 2px 8px rgba(0,0,0,0.12)",
    "--shadow-md": "0 8px 24px rgba(0,0,0,0.2)",
    "--shadow-lg": "0 16px 48px rgba(0,0,0,0.3)"
  }
}
